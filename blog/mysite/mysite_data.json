{
  "model": "blog.post",
  "pk": 3,
  "fields": {
    "title": "Classic Pancakes",
    "slug": "classic-pancakes",
    "author": 1,
    "body": "Ingredients: 1 cup flour, 1 cup milk, 1 egg, 2 tbsp sugar, 1 tsp baking powder, pinch of salt.\r\n\r\nInstructions: Mix dry ingredients. Whisk egg and milk, combine with dry mix. Pour batter on a hot pan, cook until bubbles form, flip, cook until golden. Serve with syrup or fruit.",
